          "minecraft:is_hoe_item_destructible",
          "minecraft:is_mace_item_destructible",
          "minecraft:is_pickaxe_item_destructible",
          "minecraft:is_shears_item_destructible",
          "minecraft:is_shovel_item_destructible",
